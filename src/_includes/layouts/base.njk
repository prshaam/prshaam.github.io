<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.bio }}{% endif %}">
  <meta name="theme-color" content="#0a0a0a">
  <meta name="color-scheme" content="dark">
  <script>
    (function () {
      var raw = sessionStorage.getItem("page-nav");
      if (!raw) return;
      try {
        var data = JSON.parse(raw);
        var dir = data.direction === "back" ? "back" : "forward";
        document.documentElement.classList.add("page-arriving", "page-arriving-" + dir);
      } catch (e) {
        document.documentElement.classList.add("page-arriving");
      }
    })();
  </script>
  
  <!-- Professional typography stack -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>
  <canvas id="brownian-canvas" class="brownian-canvas" aria-hidden="true"></canvas>
  <div class="page-transition-root">
    {{ content | safe }}
  </div>
  <script src="/assets/js/brownian.js" defer></script>
  <script src="/assets/js/page-transition.js" defer></script>
</body>
</html>
